# ── Configuración de entorno ──────────────────────────────
# Copia este archivo como .env y ajusta los valores.

# Clave secreta de Flask (cámbiala en producción)
SECRET_KEY=cambia-esta-clave-en-produccion

# Tamaño máximo de archivo permitido (bytes) — 10MB por defecto
MAX_CONTENT_LENGTH=10485760

# Carpeta de uploads (relativa a la raíz del proyecto)
UPLOAD_FOLDER=data/uploads

# Modo Flask: development | production
FLASK_ENV=development
